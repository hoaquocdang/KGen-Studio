# KGen Gallery — Crawl Environment Variables
# Copy this file to .env and fill in the values

# Required: Apify API Token (get from https://console.apify.com/account/integrations)
APIFY_TOKEN=your_apify_token_here

# Optional: Gemini API Key (for AI-powered prompt categorization)
# Without this, keyword-based categorization will be used instead
GEMINI_API_KEY=your_gemini_api_key_here

# Path to the gallery prompts JSON file
PROMPTS_JSON_PATH=/opt/kgen-gallery/web-ui/data/trending-prompts.json

# Base URL for hosted images
IMAGE_BASE_URL=https://images.meigen.ai/tweets

# Local directory to save downloaded images
IMAGE_DOWNLOAD_DIR=/opt/kgen-gallery/web-ui/data/images
